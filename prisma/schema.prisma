// Prisma schema — Vixus Global Investments
// Fase 0: infraestrutura + modelos de autenticação (Auth.js).
// Os modelos de domínio (Company, Party, Ownership, Ledger, Loans...) entram na Fase 1.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Conexão direta (sem pooler) para migrations. Local = DATABASE_URL; em produção
  // (Supabase) o DATABASE_URL passa pelo transaction pooler e o DIRECT_URL é a sessão.
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// Autenticação (Auth.js / @auth/prisma-adapter)
// ─────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  BOOKKEEPER
  VIEWER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(VIEWER)
  passwordHash  String? // login por credenciais (equipe interna)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────
// Domínio — empresas, donos e ownership (recursivo / UBO)
// ─────────────────────────────────────────────────────────────

enum PartyKind {
  PERSON
  ENTITY
}

enum Jurisdiction {
  PT
  BR
  US
  OTHER
}

// Tipologias (flat — a combinação válida com a jurisdição é checada na app/Zod).
enum EntityType {
  LLC
  C_CORP
  S_CORP
  PA
  LP
  LLP
  SOLE_PROP
  LTDA
  SLU
  SA
  MEI
  EI
  LDA
  UNIPESSOAL_LDA
  ENI
  OTHER
}

enum CompanyRelationship {
  GROUP_MEMBER
  MANAGED_ONLY
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
}

model Party {
  id              String       @id @default(cuid())
  kind            PartyKind
  name            String
  aliases         String[]     @default([]) // nomes alternativos/divergentes (matching de import + merge)
  taxJurisdiction Jurisdiction @default(OTHER)
  taxId           String?
  controlsTax     Boolean      @default(true) // tomamos conta do 1040 desta pessoa? false = externo (ex-sócio, K-1 de fora) — fica fora da sequência de fechamento
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  ownerStakes Ownership[] @relation("OwnerParty")
  ownedStakes Ownership[] @relation("OwnedParty")
  personalReturns PersonalReturn[]
  poolMemberships PoolMember[] @relation("PoolMemberParty")
}

model Company {
  id            String              @id @default(cuid())
  legalName     String
  tradeName     String?
  aliases       String[]            @default([]) // nomes alternativos/antigos vistos no QBO (matching de import)
  jurisdiction  Jurisdiction
  state         String? // ex.: "FL"
  entityType    EntityType
  taxId         String? // EIN / NIF / CNPJ
  formationDate String? // data de abertura/constituição (do IR ou doc societário) — p/ anos faltantes
  fiscalYearEnd String              @default("12-31")
  baseCurrency  String              @default("USD")
  relationship  CompanyRelationship
  status        CompanyStatus       @default(ACTIVE)
  collectsSalesTax Boolean          @default(false) // revende produtos → FL Sales & Use Tax
  hasEmployees     Boolean          @default(false) // folha → payroll (941/940/RT-6)
  monitored        Boolean          @default(true) // controlar no fechamento/overview? (false = ex-sócio etc.)
  controlsTax      Boolean          @default(false) // tomamos conta do IR? (gerida fora do grupo entra no closing)
  // Entidade DESCONSIDERADA (disregarded): LLC de sócio único que não declara IR próprio — o resultado é
  // consolidado no IR da dona (esta FK). Ex.: BuildPro (100% da Vixus) entra no 1065 da Vixus. É uma
  // eleição fiscal, NÃO se infere de "100% dono" (um sub 100% pode ser C-corp e declarar sozinho).
  disregardedIntoId String?
  disregardedInto   Company?  @relation("Disregarded", fields: [disregardedIntoId], references: [id], onDelete: SetNull)
  closedDate    String? // data/ano de encerramento — anos depois = N/A; ano do fecho = só IR final
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  disregardedChildren Company[]      @relation("Disregarded") // entidades desconsideradas declaradas DENTRO desta
  ownerStakes     Ownership[]        @relation("OwnerCompany")
  ownedStakes     Ownership[]        @relation("OwnedCompany")
  loansAsLender   IntercompanyLoan[] @relation("Lender")
  loansAsBorrower IntercompanyLoan[] @relation("Borrower")
  qboImports      QboImport[]
  ledgerTxns      LedgerTxn[]
  bankStatements  BankStatement[]
  taxStatuses     CompanyTaxStatus[]
  taxReturns      TaxReturn[]
  yearCloses      YearClose[]
  corporateDocs   CorporateDoc[]
  yearNotes       CompanyYearNote[]
  obligationStatuses ObligationStatus[]
  fixedAssets     FixedAsset[]
  reserveDeposits ReserveDeposit[]
  stateTaxFilings StateTaxFiling[]
  poolsAsEntity   InvestmentPool[]   @relation("PoolEntity")
  poolMemberships PoolMember[]       @relation("PoolMemberCompany")
}

// Aporte real na conta de reserva de imposto (caixa que foi movido) — para comparar com o
// necessário (funded vs needed) por trimestre.
model ReserveDeposit {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  year        Int
  quarter     Int // 1-4
  amount      Decimal   @db.Decimal(20, 4)
  purpose     String    @default("RESERVE") // RESERVE | LOAN_REPAYMENT | INTEREST | OTHER
  qboRef      String? // onde aparece no QBO da empresa (rastreabilidade)
  depositedAt DateTime? @db.Date
  note        String?
  createdAt   DateTime  @default(now())

  @@index([companyId, year])
}

// Imposto estadual de renda apurado/pago (ex.: Florida F-1120), por empresa e ano de competência.
// Separa principal (dedutível no ano de competência), multa (não dedutível §162(f)) e juros
// (dedutíveis p/ C-corp §163). A data de pagamento define em que ano o principal+multa entram como
// add-back no Schedule M-1 (foram deduzidos/lançados em anos diferentes). É a fonte que explica o
// add-back de "State income tax" sem precisar perguntar ao contador.
model StateTaxFiling {
  id           String    @id @default(cuid())
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jurisdiction String    @default("FL") // estado (FL, etc.)
  taxYear      Int // ano de competência (ex.: 2024 = F-1120 de 2024)
  principal    Decimal   @db.Decimal(20, 2) // imposto (dedutível no federal no ano de competência)
  penalty      Decimal   @default(0) @db.Decimal(20, 2) // multa — não dedutível
  interest     Decimal   @default(0) @db.Decimal(20, 2) // juros — dedutíveis p/ C-corp
  paidDate     DateTime? @db.Date // quando foi pago (define o ano do add-back no M-1)
  source       String? // origem do registro (ex.: "F-1120 notice", recibo)
  note         String?
  createdAt    DateTime  @default(now())

  @@unique([companyId, jurisdiction, taxYear])
  @@index([companyId])
}

// Ativo fixo depreciável (US/MACRS). Guarda tipo, data em serviço, custo e as opções de
// aceleração (§179 / bonus). A depreciação é CALCULADA pelo motor (macrs.ts), não armazenada.
model FixedAsset {
  id              String    @id @default(cuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name            String
  regime          String    @default("US") // US (MACRS) | PT (quotas constantes, DR 25/2009)
  category        String // US: AUTO|COMPUTER|EQUIPMENT|… ; PT: BUILDING_COMM|VEHICLE_LIGHT|…
  acquisitionDate DateTime  @db.Date // colocado em serviço / entrada em uso
  cost            Decimal   @db.Decimal(20, 4)
  recoveryYears   Decimal   @db.Decimal(4, 1) // US: 5, 7, 15, 27.5, 39… ; PT: derivado da taxa
  method          String // MACRS | SL_MM (real property) | SL_PT (quotas constantes)
  ratePct         Decimal   @default(0) @db.Decimal(6, 3) // PT: taxa anual de depreciação (%)
  landValue       Decimal   @default(0) @db.Decimal(20, 4) // PT: parcela de terreno (não deprecia)
  section179      Decimal   @default(0) @db.Decimal(20, 4) // US: deduzido no 1º ano
  bonusPct        Decimal   @default(0) @db.Decimal(5, 2) // US: % de bonus depreciation (após §179)
  // Contador depreciou o ativo TOTALMENTE no livro até este ano (ex.: tudo no ano de aquisição, ou
  // catch-up acelerado em ano posterior). Quando setado, o motor trunca: acumulada = custo até este
  // ano, e $0 depois (sem projeção futura). Confirmado pelo usuário — nunca aplicado sozinho.
  fullyDepreciatedYear Int?
  disposalDate    DateTime? @db.Date
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  yearDepreciations AssetYearDepreciation[]

  @@index([companyId])
}

// Depreciação REAL lançada nos livros, por ativo e ano (o que de fato foi depreciado). Entrada
// manual (confirmada pelo usuário) — usada para comparar com a MACRS "deveria", ativo a ativo.
model AssetYearDepreciation {
  id        String     @id @default(cuid())
  assetId   String
  asset     FixedAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  year      Int
  amount    Decimal    @db.Decimal(20, 2)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([assetId, year])
  @@index([assetId])
}

// Status de uma instância de obrigação (empresa + obrigação + período). Ausência da linha
// = pendente. Permite marcar "feito" (FILED) ou "não se aplica" (NA) no calendário.
model ObligationStatus {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  key       String // chave da obrigação (ex.: "fl-sales-tax")
  periodKey String // ex.: "2026-03", "2026-Q1", "2026"
  status    String    @default("FILED") // FILED | NA
  filedDate DateTime? @db.Date
  note      String?
  updatedAt DateTime  @updatedAt

  @@unique([companyId, key, periodKey])
  @@index([companyId])
}

// Nota livre por empresa/ano — para justificar divergências que não fecham automaticamente
// (ex.: distribuição lançada com estrutura diferente no QBO, ou no topo da cadeia sem
// contraparte) e lembrar a razão no futuro.
model CompanyYearNote {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  year      Int
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, year])
}

// Documentos societários/constitutivos (Articles of Organization, Operating Agreement,
// Sunbiz Annual Report, etc.). A Claude lê o PDF e extrai os dados oficiais (agente
// registrado, administradores/membros, endereços, nº de registro) — p/ conferir, ano a
// ano, se o que está registrado no estado bate com o IR declarado.
model CorporateDoc {
  id          String   @id @default(cuid())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  matchedName String? // nome lido no documento
  label       String? // nome dado pelo usuário (usado quando docType = OTHER, sem referência)
  docType     String // ARTICLES | OPERATING_AGREEMENT | ANNUAL_REPORT | CERTIFICATE | EIN_LETTER | OTHER
  year        Int? // ano do annual report / período
  jurisdiction String?
  state       String?
  docNumber   String? // nº de registro estadual (ex.: Sunbiz)
  taxId       String? // FEI/EIN
  formationDate String?
  filingDate    String?
  status        String?
  registeredAgent  Json? // { name, address }
  principalAddress String?
  mailingAddress   String?
  people      Json? // administradores/membros/diretores: [{ name, title, address }]
  fileName    String
  pdf         Bytes?
  pdfSize     Int?
  confidence  String?
  summary     String?
  createdAt   DateTime @default(now())
}

// Declaração de imposto da PESSOA FÍSICA (ex.: Form 1040 / IRS Tax Return Transcript).
// Fecha o ciclo entidade→sócio: confere se o K-1 que cada LLC alocou ao sócio realmente
// chegou no Schedule E do 1040 dele. SSN guardado só nos últimos 4 dígitos.
model PersonalReturn {
  id             String  @id @default(cuid())
  partyId        String?
  party          Party?  @relation(fields: [partyId], references: [id], onDelete: SetNull)
  matchedName    String? // nome do contribuinte lido no transcript
  spouseName     String?
  ssnLast4       String?
  spouseSsnLast4 String?
  year           Int?
  filingStatus   String? // ex.: "Married Filing Joint"
  form           String? // ex.: "1040"
  preparer       String?
  wages             Decimal? @db.Decimal(20, 2)
  ordinaryDividends Decimal? @db.Decimal(20, 2) // 1040 linha 3b (inclui dividendos de C-Corp)
  qualifiedDividends Decimal? @db.Decimal(20, 2) // 1040 linha 3a
  businessIncomeC   Decimal? @db.Decimal(20, 2) // Schedule C
  capitalGain       Decimal? @db.Decimal(20, 2) // Schedule D
  rentalIncome      Decimal? @db.Decimal(20, 2) // Schedule E aluguel/royalties
  partnershipIncome Decimal? @db.Decimal(20, 2) // Schedule E partnership/S-corp (renda)
  partnershipLoss   Decimal? @db.Decimal(20, 2) // Schedule E partnership/S-corp (perda)
  totalIncome       Decimal? @db.Decimal(20, 2)
  agi               Decimal? @db.Decimal(20, 2)
  taxableIncome     Decimal? @db.Decimal(20, 2)
  totalTax          Decimal? @db.Decimal(20, 2)
  seTax             Decimal? @db.Decimal(20, 2)
  qbiDeduction      Decimal? @db.Decimal(20, 2)
  confidence     String?
  summary        String?
  fileName       String
  pdf            Bytes?
  pdfSize        Int?
  createdAt      DateTime @default(now())
}

// "Fechamento" de um ano conferido: congela a verdade de referência (sócios,
// tributação e os números-chave do IR). Depois disso, um IR reenviado que
// divergir do snapshot vira alerta ("possível erro do contador"). A presença
// da linha = ano travado; reabrir = apagar a linha.
model YearClose {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  year      Int
  lockedAt  DateTime @default(now())
  lockedBy  String // e-mail do usuário que fechou
  snapshot  Json // { owners:[{name,pct,role}], taxTreatment, entityType, taxForm, figures:[{key,label,value}] }
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, year])
}

enum TaxReturnStatus {
  ANALYZED
  APPLIED
}

// IR (declaração) enviado pelo operador; a Claude extrai sócios + forma de tributação.
model TaxReturn {
  id           String          @id @default(cuid())
  fileName     String
  companyId    String?
  company      Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  matchedName  String? // nome da empresa lido no IR
  taxId        String? // EIN/CNPJ/NIF da entidade
  year         Int?
  jurisdiction String?
  entityType   String?
  taxTreatment String?
  taxForm      String? // ex.: "Form 1120-S", "1065", "ECF"
  city         String?
  state        String?
  preparer     String? // contador/escritório que preparou
  responsible  String? // ex.: Partnership Representative / responsável
  ordinaryIncome Decimal? @db.Decimal(20, 2)
  totalIncome    Decimal? @db.Decimal(20, 2)
  netIncome      Decimal? @db.Decimal(20, 2)
  businessActivity  String?
  incorporationDate String?
  address           String?
  // ⚠️ NÃO ler `figures` direto em telas/cálculos — use effectiveFiguresOf(ret) de @/lib/ir/figures
  // (mescla `figures` + `manualFigures`). Ler só `figures` ignora os ajustes manuais = fonte de verdade
  // divergente. Ver o helper para a lista de consumidores.
  figures      Json? // linhas LIDAS do IR (IA): [{ key, label, value, line }]
  manualFigures Json? // ajustes MANUAIS auditáveis: [{ key, label, value, line, note, addedAt }] —
  // ex.: depreciação que estava no IR mas não destacada/extraída. Sobrepõe `figures` por key.
  confidence   String?
  summary      String?
  owners       Json? // [{ name, taxIdLast4, ownershipPct, allocatedIncome, role }]
  k1sReceived  Json? // K-1 RECEBIDOS de investidas: [{ issuerName, issuerEin, amount }]
  isFinalReturn Boolean @default(false) // "Final return" marcado (entidade encerrada no ano)
  pdf          Bytes? // arquivo original, para consulta/registro
  pdfSize      Int?
  status       TaxReturnStatus @default(ANALYZED)
  createdAt    DateTime        @default(now())
}

// Forma de tributação (independe do tipo legal — ex.: LLC tributada como S-corp).
enum TaxTreatment {
  // EUA
  DISREGARDED // LLC single-member (Schedule C/E)
  PARTNERSHIP // 1065
  S_CORP // 1120-S
  C_CORP // 1120
  SOLE_PROP // Schedule C
  // Brasil
  LUCRO_REAL
  LUCRO_PRESUMIDO
  SIMPLES_NACIONAL
  MEI
  // Portugal
  REGIME_GERAL
  REGIME_SIMPLIFICADO
  OTHER
}

// Classificação tributária por ANO (muda ao longo do tempo).
model CompanyTaxStatus {
  id           String       @id @default(cuid())
  companyId    String
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  year         Int
  entityType   EntityType // tipo legal naquele ano
  taxTreatment TaxTreatment // como foi tributada naquele ano
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([companyId, year])
}

// Alíquota de reserva de IR (provisão mensal). `companyId` = id da empresa, ou o
// sentinela "GLOBAL" para o default do grupo. Sem FK (por causa do sentinela).
model TaxReserveRate {
  companyId String   @id // id da empresa ou "GLOBAL"
  ratePct   Decimal  @db.Decimal(5, 2)
  updatedAt DateTime @updatedAt
}

// Alíquotas de provisão por ANO (mudam no tempo). C-corp = federal 21%; pass-through/PF = 30%;
// Florida corporate 5,5% + isenção $50k. Override por empresa continua em TaxReserveRate.
model TaxRateYear {
  year        Int      @id
  corpPct     Decimal  @default(21) @db.Decimal(5, 2)
  passPct     Decimal  @default(30) @db.Decimal(5, 2)
  flPct       Decimal  @default(5.5) @db.Decimal(5, 2)
  flExemption Decimal  @default(50000) @db.Decimal(20, 2)
  updatedAt   DateTime @updatedAt
}

// Fechamento da provisão de um ANO: snapshot dos números no momento do fecho. Trava a tela
// (somente leitura) — é provisão, pode reabrir, mas o snapshot fica como registro.
model ReserveLock {
  year     Int      @id
  lockedAt DateTime @default(now())
  snapshot Json
}

// ─────────────────────────────────────────────────────────────
// Importações do QuickBooks (QBO) — relatórios em CSV
// ─────────────────────────────────────────────────────────────

enum QboReportKind {
  BALANCE_SHEET
  PROFIT_AND_LOSS
  GENERAL_LEDGER
  UNKNOWN
}

model QboImport {
  id                String        @id @default(cuid())
  companyId         String?
  company           Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  sourceCompanyName String // nome exatamente como veio no CSV
  reportKind        QboReportKind
  reportTypeLabel   String
  periodLabel       String
  basis             String?
  fileName          String?
  columns           String[]
  createdAt         DateTime      @default(now())

  lines            QboImportLine[]
  ledgerTxns       LedgerTxn[]
  accountSummaries GlAccountSummary[]
}

// Saldo por conta extraído de um General Ledger (saldo inicial/final da seção).
// Permite cruzar o razão com o Balance Sheet (saldo final) e o P&L (movimento).
model GlAccountSummary {
  id        String    @id @default(cuid())
  importId  String
  import    QboImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  companyId String
  account   String
  beginning Decimal?  @db.Decimal(20, 4)
  ending    Decimal?  @db.Decimal(20, 4)

  @@index([companyId])
  @@index([importId])
}

// Contato (fornecedor/cliente/contraparte) — populado da coluna "Name" do GL.
model Vendor {
  id               String      @id @default(cuid())
  name             String
  normalizedKey    String      @unique
  matchedCompanyId String?
  matchedPartyId   String?
  createdAt        DateTime    @default(now())
  txns             LedgerTxn[]
}

// Extrato bancário importado (por banco/adaptador) — para reconciliação.
model BankStatement {
  id               String    @id @default(cuid())
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bankId           String // "boa", etc.
  bankLabel        String
  glAccount        String? // conta-caixa correspondente no GL (escopa a conciliação)
  fileName         String?
  periodStart      DateTime? @db.Date
  periodEnd        DateTime? @db.Date
  beginningBalance Decimal?  @db.Decimal(20, 4)
  endingBalance    Decimal?  @db.Decimal(20, 4)
  createdAt        DateTime  @default(now())

  lines BankStatementLine[]
}

enum BankLineStatus {
  UNREVIEWED
  MATCHED
  FLAGGED // no razão falta o lançamento (booking faltante)
  IGNORED
}

model BankStatementLine {
  id           String         @id @default(cuid())
  statementId  String
  statement    BankStatement  @relation(fields: [statementId], references: [id], onDelete: Cascade)
  date         DateTime       @db.Date
  description  String
  amount       Decimal        @db.Decimal(20, 4)
  balance      Decimal?       @db.Decimal(20, 4)
  matchedTxnId String? // LedgerTxn reconciliada (no split, o 1º dos lançamentos)
  matchedTxnIds String[] @default([]) // todos os lançamentos casados (split = N)
  matchNote    String? // ex.: "split — 3 entries" (1 linha do banco = N lançamentos no GL)
  status       BankLineStatus @default(UNREVIEWED)
  note         String?
  reviewedAt   DateTime?
  createdAt    DateTime       @default(now())
}

// Linha do razão (General Ledger) — uma transação por conta.
model LedgerTxn {
  id          String     @id @default(cuid())
  companyId   String
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  importId    String?
  import      QboImport? @relation(fields: [importId], references: [id], onDelete: SetNull)
  account     String
  date        DateTime   @db.Date
  type        String
  num         String?
  vendorId    String?
  vendor      Vendor?    @relation(fields: [vendorId], references: [id])
  rawName     String?
  description String?
  split       String?
  amount      Decimal    @db.Decimal(20, 4)
  currency    String     @default("USD")
  createdAt   DateTime   @default(now())

  @@index([companyId, account])
  @@index([companyId, date])
}

// Taxas de câmbio travadas por data (buscadas online, ex.: fim de mês).
model FxRate {
  id        String   @id @default(cuid())
  base      String // moeda base, ex.: "USD"
  quote     String // moeda cotada, ex.: "BRL", "EUR" (1 base = rate quote)
  date      DateTime @db.Date
  rate      Decimal  @db.Decimal(18, 8)
  source    String   @default("frankfurter")
  fetchedAt DateTime @default(now())

  @@unique([base, quote, date])
}

model QboImportLine {
  id          String    @id @default(cuid())
  importId    String
  import      QboImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  rowIndex    Int
  label       String
  accountCode String?
  sectionPath String[]
  depth       Int
  lineType    String // SECTION | ACCOUNT | TOTAL
  value       Decimal?  @db.Decimal(20, 4) // valor da 1ª coluna de período
  currency    String    @default("USD")
}

/// Aresta de participação genérica. Dono e possuído podem ser Party OU Company,
/// permitindo a árvore recursiva até o beneficiário final (UBO).
/// Regra (validada na app): exatamente UM owner* e UM owned* preenchidos.
model Ownership {
  id String @id @default(cuid())

  ownerPartyId   String?
  ownerParty     Party?   @relation("OwnerParty", fields: [ownerPartyId], references: [id])
  ownerCompanyId String?
  ownerCompany   Company? @relation("OwnerCompany", fields: [ownerCompanyId], references: [id])

  ownedCompanyId String?
  ownedCompany   Company? @relation("OwnedCompany", fields: [ownedCompanyId], references: [id])
  ownedPartyId   String?
  ownedParty     Party?   @relation("OwnedParty", fields: [ownedPartyId], references: [id])

  percentage    Decimal   @db.Decimal(9, 6) // 0–100
  shareClass    String?
  effectiveDate DateTime  @default(now())
  endDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ─────────────────────────────────────────────────────────────
// Empréstimos intercompany (juros simples + origination fee)
// ─────────────────────────────────────────────────────────────

enum LoanStatus {
  ACTIVE
  PAID
  DEFAULTED
  CANCELLED
}

enum LoanInterestMethod {
  SIMPLE
  COMPOUND
}

enum DayCountBasis {
  ACT_365
  ACT_360
  D30_360
}

enum LoanTxnType {
  DISBURSEMENT
  ORIGINATION_FEE
  INTEREST_ACCRUAL
  REPAYMENT_PRINCIPAL
  REPAYMENT_INTEREST
  ADJUSTMENT
}

model IntercompanyLoan {
  id                String   @id @default(cuid())
  lenderCompanyId   String
  lender            Company  @relation("Lender", fields: [lenderCompanyId], references: [id])
  borrowerCompanyId String
  borrower          Company  @relation("Borrower", fields: [borrowerCompanyId], references: [id])

  principal          Decimal            @db.Decimal(20, 4)
  currency           String             @default("USD")
  annualInterestRate Decimal            @db.Decimal(9, 6) // fração anual: 0.085 = 8,5%
  interestMethod     LoanInterestMethod @default(SIMPLE)
  dayCountBasis      DayCountBasis      @default(ACT_365)
  originationFeeRate Decimal            @default(0.01) @db.Decimal(9, 6) // configurável; padrão 1%

  startDate    DateTime
  maturityDate DateTime?
  status       LoanStatus @default(ACTIVE)
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  transactions LoanTransaction[]
  years        LoanYear[]
  poolAsNote   InvestmentPool?   @relation("PoolNote")
}

// Valores FORNECIDOS por ano de um empréstimo intercompany (do contador/QBO). O app não
// recalcula o juro — guarda o que é informado e faz o roll-forward do juro não pago para uma
// conta SEPARADA (juro capitalizado), que fica apartada do principal para bater com o QBO.
// AGENDA por ano de um empréstimo: taxa vigente + juro pago no ano. O PRINCIPAL é fonte única em
// LoanTransaction (buildAnnualClosings/computeLoanBalance); o juro accrued é CALCULADO. As colunas de
// principal/accrued vestigiais foram removidas (migração drop_loanyear_vestigial, com guarda anti-perda).
model LoanYear {
  id            String           @id @default(cuid())
  loanId        String
  loan          IntercompanyLoan @relation(fields: [loanId], references: [id], onDelete: Cascade)
  year          Int
  annualRatePct Decimal?         @db.Decimal(9, 4) // taxa do ano (%, reajustável) — USADO
  interestPaid  Decimal          @default(0) @db.Decimal(20, 2) // juro pago no ano (fornecido) — USADO
  note          String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([loanId, year])
}

model LoanTransaction {
  id     String           @id @default(cuid())
  loanId String
  loan   IntercompanyLoan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  type      LoanTxnType
  amount    Decimal     @db.Decimal(20, 4)
  date      DateTime
  memo      String?
  createdAt DateTime    @default(now())
}

// ─────────────────────────────────────────────────────────────
// Investment pools — LLCs de investimento por projeto (VHP-N)
// Cada pool = uma empresa (cap table congelado, encerra com o projeto). Funcionários
// investem via empresas deles (Party/Company); a Vixus entra como MANAGER e sócia de
// equilíbrio. Units de valor fixo: % de cada sócio é derivado, nunca digitado.
// ─────────────────────────────────────────────────────────────

enum PoolStatus {
  FUNDING // captando (aportes emitem units)
  ACTIVE // cap table congelado; obra/vendas em andamento (só transferências de units)
  CLOSING // vendas concluídas; distribuindo capital + lucro
  CLOSED // encerrado (IR final)
}

enum PoolHouseStatus {
  PLANNED
  LOT_PURCHASED
  UNDER_CONSTRUCTION
  FOR_SALE
  UNDER_CONTRACT
  SOLD
}

enum PoolMemberRole {
  MANAGER // Vixus — gestão e sócia de equilíbrio
  INVESTOR // classe sem voto
}

enum PoolEntryKind {
  CONTRIBUTION // aporte na janela de captação (emite units)
  TRANSFER_IN // compra de units de outro sócio (par com TRANSFER_OUT)
  TRANSFER_OUT
  CAPITAL_CALL // aporte de chamada de capital (pro rata; valor exato, sem regra de múltiplo)
}

enum PoolDistributionKind {
  RETURN_OF_CAPITAL
  PROFIT
}

model InvestmentPool {
  id    String  @id @default(cuid())
  code  String  @unique // sequencial: "VHP-I", "VHP-II"…
  name  String // razão social: "Vixus Home Partners I LLC"
  alias String? // nome legado do projeto (ex.: "PH3")

  // Pool LLC registrada como empresa do grupo (org-chart, IR, year-close funcionam nela).
  companyId String?  @unique
  company   Company? @relation("PoolEntity", fields: [companyId], references: [id], onDelete: SetNull)

  // Nota participativa única do pool para a Vixus (formato empréstimo). Os juros-base
  // vivem no loan; os contingentes saem do waterfall do pool.
  noteLoanId String?           @unique
  noteLoan   IntercompanyLoan? @relation("PoolNote", fields: [noteLoanId], references: [id], onDelete: SetNull)

  status   PoolStatus @default(FUNDING)
  currency String     @default("USD")

  unitPrice      Decimal  @default(1000) @db.Decimal(20, 4) // 1 unit = $1.000
  targetAmount   Decimal? @db.Decimal(20, 2) // orçamento de captação (own capital do pool)
  profitSharePct Decimal? @db.Decimal(9, 6) // fração do lucro que vai aos investidores (0.35 = 35%)
  profitShareTiming String? // PER_SALE | PROJECT_COMPLETION

  fundingDeadline  DateTime? @db.Date // corte da janela de captação (compra dos lotes)
  startDate        DateTime? @db.Date
  plannedEndDate   DateTime? @db.Date
  effectiveEndDate DateTime? @db.Date

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  houses        PoolHouse[]
  members       PoolMember[]
  distributions PoolDistribution[]
  documents     PoolDocument[]
  simulations   PoolSimulation[]
  loan          PoolLoan?
  capitalCalls  PoolCapitalCall[]
  expenses      PoolExpense[]
}

// Uma casa do pool: pro forma (esperado) + premissas do banco + realizado. O nº de casas é
// variável — dimensionado pelo volume captado + alavancagem por casa.
model PoolHouse {
  id     String         @id @default(cuid())
  poolId String
  pool   InvestmentPool @relation(fields: [poolId], references: [id], onDelete: Cascade)

  address String
  status  PoolHouseStatus @default(PLANNED)

  // Toda casa nasce de um MODELO do simulador numa LOCALIZAÇÃO (regra inicial); o endereço
  // vem depois do lote. Pode ser trocado (raro — gera variação simulado × real, ok).
  catalogModelId    String?
  catalogModel      CatalogModel?    @relation(fields: [catalogModelId], references: [id])
  catalogLocationId String?
  catalogLocation   CatalogLocation? @relation(fields: [catalogLocationId], references: [id])

  // Pro forma (esperado)
  plannedLotCost     Decimal? @db.Decimal(20, 2)
  plannedBuildCost   Decimal? @db.Decimal(20, 2)
  plannedSalePrice   Decimal? @db.Decimal(20, 2)
  plannedClosingCost Decimal? @db.Decimal(20, 2)

  // Premissas do construction loan
  bankName            String?
  bankLoanAmount      Decimal? @db.Decimal(20, 2)
  bankOriginationFee  Decimal? @db.Decimal(20, 2)
  bankInterestReserve Decimal? @db.Decimal(20, 2)
  bankCashToClose     Decimal? @db.Decimal(20, 2)
  bankBudgetReviewFee Decimal? @db.Decimal(20, 2)
  bankCharges         Decimal? @db.Decimal(20, 2)

  // Realizado
  actualLotCost   Decimal?  @db.Decimal(20, 2)
  actualBuildCost Decimal?  @db.Decimal(20, 2)
  ownCapital      Decimal?  @db.Decimal(20, 2) // capital próprio efetivamente usado na casa
  soldPrice       Decimal?  @db.Decimal(20, 2)
  payoffAmount    Decimal?  @db.Decimal(20, 2) // quitação do banco na venda
  netReceived     Decimal?  @db.Decimal(20, 2) // o que ENTROU em conta no closing
  closingCost     Decimal?  @db.Decimal(20, 2) // = venda − payoff − recebido (derivável)
  contractDate    DateTime? @db.Date
  saleDate        DateTime? @db.Date

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  distributions PoolDistribution[]
  loanEntries   PoolLoanEntry[]
  changeOrders  HouseChangeOrder[]

  @@index([poolId])
}

// Change order (CO) da casa: despesa/crédito que altera o valor do contrato. Entra no
// custo real da casa (lucro por custo) e na conta de necessidade de capital do pool.
model HouseChangeOrder {
  id          String    @id @default(cuid())
  houseId     String
  house       PoolHouse @relation(fields: [houseId], references: [id], onDelete: Cascade)
  date        DateTime  @db.Date
  description String
  amount      Decimal   @db.Decimal(20, 2) // positivo = custo extra; negativo = crédito
  createdAt   DateTime  @default(now())

  @@index([houseId])
}

// Despesas do PRÓPRIO pool (não das casas): abertura da LLC, annual report, contabilidade/
// IR para gerar os K-1s. PROVISIONED = previsto (reserva no caixa); PAID = pago. Saem do
// caixa do pool antes do lucro → rateio automático pro rata às units (padrão do 1065/K-1).
model PoolExpense {
  id          String         @id @default(cuid())
  poolId      String
  pool        InvestmentPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  date        DateTime       @db.Date
  category    String // FORMATION | ANNUAL_REPORT | TAX_PREP | ACCOUNTING | OTHER
  description String
  amount      Decimal        @db.Decimal(20, 2)
  status      String         @default("PROVISIONED") // PROVISIONED | PAID
  createdAt   DateTime       @default(now())

  @@index([poolId])
}

// Chamada de capital: quando custos (ex.: COs) passam do captado, o pool chama capital
// PRO RATA às units. Gera o relatório para os sócios; cada linha recebida vira um aporte
// (kind CAPITAL_CALL) — aumentando a base de retorno do investidor.
model PoolCapitalCall {
  id          String         @id @default(cuid())
  poolId      String
  pool        InvestmentPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  date        DateTime       @db.Date
  totalAmount Decimal        @db.Decimal(20, 2)
  reason      String // motivo (ex.: "Change orders casa X + juros sem reserve")
  memo        String?
  createdAt   DateTime       @default(now())

  lines PoolCapitalCallLine[]

  @@index([poolId])
}

model PoolCapitalCallLine {
  id             String          @id @default(cuid())
  callId         String
  call           PoolCapitalCall @relation(fields: [callId], references: [id], onDelete: Cascade)
  memberId       String
  member         PoolMember      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  amount         Decimal         @db.Decimal(20, 2) // pro rata às units na data da chamada
  paid           Boolean         @default(false)
  contributionId String?         @unique // aporte gerado no recebimento
}

// Sócio do pool — Party OU Company (exatamente um, validado na app; mesmo padrão de Ownership).
model PoolMember {
  id     String         @id @default(cuid())
  poolId String
  pool   InvestmentPool @relation(fields: [poolId], references: [id], onDelete: Cascade)

  partyId   String?
  party     Party?   @relation("PoolMemberParty", fields: [partyId], references: [id])
  companyId String?
  company   Company? @relation("PoolMemberCompany", fields: [companyId], references: [id])

  role PoolMemberRole @default(INVESTOR)

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries           PoolContribution[]
  distributionLines PoolDistributionLine[]
  capitalCallLines  PoolCapitalCallLine[]

  @@index([poolId])
}

// Lançamento de capital do sócio (o "extrato"): aporte emite units; transferência move units
// entre sócios sem diluir ninguém (par OUT/IN com o mesmo transferGroupId). Valores sempre
// positivos — TRANSFER_OUT subtrai no cálculo da posição.
model PoolContribution {
  id       String     @id @default(cuid())
  memberId String
  member   PoolMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  kind            PoolEntryKind @default(CONTRIBUTION)
  date            DateTime      @db.Date
  amount          Decimal       @db.Decimal(20, 2)
  units           Decimal       @db.Decimal(20, 4)
  transferGroupId String? // liga o par TRANSFER_OUT/TRANSFER_IN
  memo            String?
  createdAt       DateTime      @default(now())

  @@index([memberId])
}

// Distribuição aos sócios (devolução de capital ou lucro), rateada pro rata por units na
// data. As linhas guardam o valor de cada sócio como ficou no rateio (auditável).
model PoolDistribution {
  id     String         @id @default(cuid())
  poolId String
  pool   InvestmentPool @relation(fields: [poolId], references: [id], onDelete: Cascade)

  kind        PoolDistributionKind
  date        DateTime             @db.Date
  totalAmount Decimal              @db.Decimal(20, 2)
  houseId     String? // venda que originou a distribuição (opcional)
  house       PoolHouse?           @relation(fields: [houseId], references: [id], onDelete: SetNull)
  memo        String?
  createdAt   DateTime             @default(now())

  lines PoolDistributionLine[]

  @@index([poolId])
}

model PoolDistributionLine {
  id             String           @id @default(cuid())
  distributionId String
  distribution   PoolDistribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  memberId       String
  member         PoolMember       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  amount         Decimal          @db.Decimal(20, 2)
}

// ─────────────────────────────────────────────────────────────
// Simulador de tese de investimento (pré-pool)
// Catálogos de locais/modelos/fees + perfis de banco + cenários de buffer, e as
// simulações salvas (ledger enviado ao investidor antes do projeto).
// ─────────────────────────────────────────────────────────────

enum HouseType {
  AFFORDABLE
  MID_RANGE
  UPPER_MIDDLE
  HIGH_END
  LUXURY
  DUPLEX
  TRIPLEX
  MULTIFAMILY
}

enum SimFundingMode {
  EQUITY
  BANK
}

// Remuneração da 4U (construtora): fee fixo por tipo de casa (sem participação), OU
// performance = % do lucro líquido ANTES do split com investidores (default 35%), OU
// promote = waterfall com tiers programáveis (capital de volta → pref → promote por faixa).
enum BuilderCompMode {
  CONTRACTOR_FEE
  PERFORMANCE
  PROMOTE
}

// Plano de desembolso da obra (6 fases). LIGHT_START reduz a exposição inicial: até o
// permit caem 25% (vs 40% no padrão) — capital inicial ≈ lote + 25% da obra.
enum SimPaymentPlan {
  STANDARD // 10/30/20/20/15/5
  LIGHT_START // 10/15/25/25/20/5
}

model CatalogLocation {
  id              String   @id @default(cuid())
  name            String   @unique
  permitDays      Int
  lotLeadDays     Int // dias até fechar a compra do lote
  saleDays        Int // dias para vender após CO
  lotCostEstimate Decimal? @db.Decimal(20, 2) // valor estimado de lote na região
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  models     CatalogModelLocation[]
  poolHouses PoolHouse[]
}

model CatalogModel {
  id            String    @id @default(cuid())
  name          String    @unique
  houseType     HouseType
  buildMonths   Decimal   @db.Decimal(4, 1)
  contractorFee Decimal?  @db.Decimal(20, 2) // override; null = usa o fee do tipo (HouseTypeFee)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  locations  CatalogModelLocation[]
  poolHouses PoolHouse[]
}

// Valores do modelo POR local: venda e os DOIS custos de obra. Performance = custo quando a
// 4U participa do lucro (ex.: Arpoador em Marion Oaks $202k). Contractor = custo-base SEM o
// fee; o custo final é costContractor + fee do tipo (ex.: $185k + $25k = $210k). O lote vem
// sempre do lotCostEstimate do location — não é definido aqui.
model CatalogModelLocation {
  id              String          @id @default(cuid())
  modelId         String
  model           CatalogModel    @relation(fields: [modelId], references: [id], onDelete: Cascade)
  locationId      String
  location        CatalogLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  salePrice       Decimal         @db.Decimal(20, 2)
  costPerformance Decimal?        @db.Decimal(20, 2) // custo de obra na modalidade performance
  costContractor  Decimal?        @db.Decimal(20, 2) // custo-base contractor (sem o fee do tipo)

  @@unique([modelId, locationId])
}

// Contractor fee fixo por tipo de casa (preenchido pelo usuário).
model HouseTypeFee {
  type      HouseType @id
  fee       Decimal   @default(0) @db.Decimal(20, 2)
  updatedAt DateTime  @updatedAt
}

// Premissas de um banco de construction loan — ajustável por banco. Estrutura validada
// contra o transaction history real do loan 77959 (Builders Capital, "Vixus 8 SFR"):
// fees itemizados no closing (podem ser % do comprometido, fixos ou CRÉDITOS negativos),
// reserve capitalizada que paga o juro mensal e devolve o não usado na reconciliação,
// fees por draw/lote de draws, reconveyance por payoff e sweep 85% com quitação na última.
model BankProfile {
  id   String @id @default(cuid())
  name String @unique

  // 1 · Dimensionamento
  ltcBuildPct Decimal  @default(80) @db.Decimal(5, 2) // % do custo de obra
  ltcLandPct  Decimal  @default(50) @db.Decimal(5, 2) // % do lote (se financia)
  financeLand Boolean  @default(false)
  ltvPct      Decimal  @default(70) @db.Decimal(5, 2) // % do ARV
  haircutPct  Decimal  @default(5) @db.Decimal(5, 2) // desconto de avaliação sobre ARV
  perUnitCap  Decimal? @db.Decimal(20, 2)
  // O banco autoriza o closing quando X% dos permits estão emitidos (ex.: 10 casas → 8º
  // permit libera). Arredonda para cima (ceil).
  closingPermitPct Decimal @default(80) @db.Decimal(5, 2)

  // 2 · Juros
  rateType      BankRateType      @default(FIXED) // fixa | prime+spread | SOFR+spread
  aprPct        Decimal           @default(12) @db.Decimal(6, 3) // taxa fixa a.a.
  indexPct      Decimal           @default(0) @db.Decimal(6, 3) // índice atual (prime/SOFR)
  spreadPct     Decimal           @default(0) @db.Decimal(6, 3)
  interestBasis BankInterestBasis @default(DRAWN) // sacado (non-Dutch) | comprometido (Dutch)

  // 3 · No closing (vazio/0 = banco não cobra)
  originationPct  Decimal @default(1) @db.Decimal(5, 2) // pontos, % do comprometido
  originationFlat Decimal @default(0) @db.Decimal(20, 2)
  brokerPct       Decimal @default(0) @db.Decimal(5, 2) // % do comprometido
  titleEscrowPct  Decimal @default(0) @db.Decimal(5, 2) // % do comprometido
  closingFeePct   Decimal @default(0) @db.Decimal(5, 2) // outros custos de closing, % genérico
  processingFee   Decimal @default(0) @db.Decimal(20, 2)
  budgetReviewFee Decimal @default(0) @db.Decimal(20, 2)
  appraisalFee    Decimal @default(0) @db.Decimal(20, 2)
  legalFee        Decimal @default(0) @db.Decimal(20, 2)
  feesFinanced    Boolean @default(true) // capitalizam no loan (senão saem do caixa)

  // 4 · Durante a obra
  servicingMonthly     Decimal @default(0) @db.Decimal(20, 2)
  inspectionFeePerDraw Decimal @default(0) @db.Decimal(20, 2)
  drawProcessingFee    Decimal @default(0) @db.Decimal(20, 2)
  achFeePerBatch       Decimal @default(0) @db.Decimal(20, 2) // por LOTE de draws (mesma data)

  // Interest reserve: financiada no closing (capitaliza), o juro mensal consome a reserve
  // (sem compor), e o NÃO USADO é creditado na reconciliação final (reduz o último payoff).
  hasInterestReserve Boolean @default(false)
  reserveMonths      Decimal @default(6) @db.Decimal(4, 1) // sizing: meses de juro sobre o comprometido

  // 5 · Na venda / payoff
  releaseMode     BankReleaseMode @default(SWEEP_FULL) // 100% do líquido | sweep% + quitação na última
  sweepPct        Decimal         @default(100) @db.Decimal(5, 2)
  reconveyanceFee Decimal         @default(0) @db.Decimal(20, 2) // por payoff (release da casa)

  // 6 · Prazo (extension: >50% do original devido → % sobre TODO o financiado; senão só
  // sobre o saldo. Aplicada apenas no cenário Conservador da simulação.)
  termMonths      Int     @default(12)
  extensionMonths Int     @default(6)
  extensionFeePct Decimal @default(1) @db.Decimal(5, 2)

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customFees  BankCustomFee[]
  simulations PoolSimulation[]
  poolLoans   PoolLoan[]
}

enum BankRateType {
  FIXED
  PRIME_SPREAD
  SOFR_SPREAD
}

enum BankInterestBasis {
  DRAWN // juro só sobre o sacado (non-Dutch)
  COMMITTED // juro sobre o total comprometido desde o dia 1 (Dutch)
}

enum BankReleaseMode {
  SWEEP_FULL // 100% do líquido de cada venda até quitar
  SWEEP_PCT_LAST_FULL // sweep% nas vendas; última casa quita o saldo (Builders Capital)
}

enum BankFeeTiming {
  CLOSING
  PER_DRAW
  PER_DRAW_BATCH // por data com draws (ex.: ACH)
  MONTHLY
  PER_PAYOFF
  FINAL // na reconciliação final
}

enum BankFeeKind {
  FLAT // valor fixo (pode ser NEGATIVO — ex.: LO credit)
  PCT_COMMITTED // % do loan comprometido
  PCT_PAYOFF // % do payoff (exit fee)
}

// Taxas específicas de cada banco que não se encaixam nos campos padrão — o motor soma
// cada uma no momento certo (closing/draw/lote/mês/payoff/final).
model BankCustomFee {
  id            String        @id @default(cuid())
  bankProfileId String
  bankProfile   BankProfile   @relation(fields: [bankProfileId], references: [id], onDelete: Cascade)
  name          String
  timing        BankFeeTiming @default(CLOSING)
  kind          BankFeeKind   @default(FLAT)
  amount        Decimal       @db.Decimal(20, 2) // negativo = crédito
  createdAt     DateTime      @default(now())

  @@index([bankProfileId])
}

// Cenário de buffers (docx "Investment Thesis Simulator - Buffers"): OPT/REAL/CONS + customs.
model BufferScenario {
  code                        String   @id // "OPT" | "REAL" | "CONS" | customizados
  name                        String
  salePriceBufferPct          Decimal  @default(0) @db.Decimal(6, 2) // +5 / 0 / −7
  constructionCostBufferPct   Decimal  @default(0) @db.Decimal(6, 2) // −2 / 0 / +10
  lotCostBufferPct            Decimal  @default(0) @db.Decimal(6, 2) // −1 / 0 / +5
  closingFeePct               Decimal  @default(8) @db.Decimal(6, 2) // 7.5 / 8 / 9 (% da venda)
  contingencyReservePct       Decimal  @default(5) @db.Decimal(6, 2) // 3 / 5 / 8 (% de lote+obra)
  landAcquisitionDays         Int      @default(20) // atraso na compra do lote: 10 / 20 / 30
  constructionDurationBufferM Decimal  @default(0) @db.Decimal(4, 1) // −1 / 0 / +2 meses
  salesAbsorptionMonths       Decimal? @db.Decimal(4, 1) // 1 / 2 / 4 (null = saleDays do local)
  emdPct                      Decimal  @default(10) @db.Decimal(6, 2) // 5 / 10 / 10
  stressSlippagePct           Decimal  @default(0) @db.Decimal(6, 2)
  sortOrder                   Int      @default(0)
  updatedAt                   DateTime @updatedAt

  simulations PoolSimulation[]
}

// Trilha de auditoria dos catálogos do simulador: cada save registra quem mudou o quê
// (campo a campo, valor anterior → novo). Nunca é apagada — histórico exibido no modal.
model CatalogChangeLog {
  id         String   @id @default(cuid())
  entity     String // LOCATION | MODEL | MODEL_LOCATION | BANK | SCENARIO | TYPE_FEE
  entityId   String
  entityName String // nome no momento da mudança (sobrevive a delete/rename)
  action     String   @default("UPDATE") // CREATE | UPDATE | DELETE
  changedBy  String // e-mail do usuário logado
  changes    Json // [{ field, from, to }]
  createdAt  DateTime @default(now())

  @@index([entity, entityId])
}

// Simulação salva (a "tese" enviada ao investidor). `units` = [{locationId, modelId}];
// `result` = snapshot do ledger/KPIs no momento do run (o que foi apresentado).
model PoolSimulation {
  id     String          @id @default(cuid())
  poolId String?
  pool   InvestmentPool? @relation(fields: [poolId], references: [id], onDelete: SetNull)

  name          String
  fundingMode   SimFundingMode  @default(BANK)
  bankProfileId String?
  bankProfile   BankProfile?    @relation(fields: [bankProfileId], references: [id])
  scenarioCode  String          @default("REAL")
  scenario      BufferScenario  @relation(fields: [scenarioCode], references: [code])
  compMode      BuilderCompMode @default(PERFORMANCE)
  perfPct       Decimal         @default(35) @db.Decimal(5, 2) // % do lucro p/ 4U, ANTES do split
  perfTiming    String          @default("PROJECT_COMPLETION") // PER_SALE | PROJECT_COMPLETION
  // Promote (waterfall): tiers programáveis [{hurdle: % a.a. sobre o capital médio em risco
  // (null = acima do último), promote: % da faixa para a 4U}]. Pago na conclusão.
  promoteTiers  Json?
  paymentPlan   SimPaymentPlan  @default(STANDARD)
  equityGatePct Decimal         @default(10) @db.Decimal(5, 2) // mínimo p/ iniciar sem banco
  parallelPermit Boolean        @default(false)
  unitGapDays   Int             @default(3)

  units  Json // [{ locationId, modelId }]
  result Json? // snapshot: { kpis, events[], monthly[], units[] }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// Statement interno do construction loan (por pool) — replica o transaction history do
// banco SEM depender de extrato: draws por casa, juros mensais reais, fees e payoffs
// lançados manualmente; saldo devido calculado; cada linha pode ser conciliada (✓) contra
// o extrato do banco. Convenção de sinal = extrato do banco: charge positivo, pagamento
// negativo; saldo = soma acumulada.
// ─────────────────────────────────────────────────────────────

enum PoolLoanEntryType {
  CLOSING_FEE // fees do closing (origination, broker, title, etc.)
  RESERVE // interest reserve financiada (capitaliza)
  DRAW // draw do banco (ligado à casa)
  DRAW_FEE // inspection / processing / ACH
  INTEREST // juro mensal REAL cobrado pelo banco
  INTEREST_PAYMENT // pagamento do juro (ex.: debitado da reserve) — negativo
  PAYOFF // principal quitado na venda — negativo
  RECONVEYANCE // fee de release por payoff
  CREDIT // créditos (LO credit, devolução de reserve) — negativo
  OTHER
}

model PoolLoan {
  id     String         @id @default(cuid())
  poolId String         @unique // um construction loan por pool (v1)
  pool   InvestmentPool @relation(fields: [poolId], references: [id], onDelete: Cascade)

  bankProfileId String?
  bankProfile   BankProfile? @relation(fields: [bankProfileId], references: [id])
  loanNumber    String? // ex.: "77959"
  committed     Decimal?  @db.Decimal(20, 2) // valor comprometido
  aprPct        Decimal?  @db.Decimal(6, 3) // taxa contratual (p/ conferência dos juros)
  expectedClosingDate DateTime? @db.Date // closing PREVISTO (regra dos 80% dos permits)
  closingDate   DateTime? @db.Date // closing REAL
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  entries PoolLoanEntry[]
}

model PoolLoanEntry {
  id     String   @id @default(cuid())
  loanId String
  loan   PoolLoan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  houseId String? // draw/payoff/reconveyance de uma casa específica
  house   PoolHouse? @relation(fields: [houseId], references: [id], onDelete: SetNull)

  type       PoolLoanEntryType
  date       DateTime          @db.Date // DRAW: data do CRÉDITO
  amount     Decimal           @db.Decimal(20, 2) // + aumenta a dívida, − reduz; DRAW: liberado
  // Só para DRAW: o que foi SOLICITADO ao banco e quando (liberado pode diferir)
  requestedAmount Decimal?  @db.Decimal(20, 2)
  requestDate     DateTime? @db.Date
  // Draw AGUARDANDO resposta do banco: não entra no saldo nem gera fees até a liberação
  pending         Boolean   @default(false)
  memo       String?
  reconciled Boolean           @default(false) // conferido contra o extrato do banco
  createdAt  DateTime          @default(now())

  @@index([loanId, date])
}

// PDFs do pool (subscription agreement, cap table, nota, novação, extratos, closing
// statement) — gerados pela plataforma ou anexados; Bytes no Postgres como CorporateDoc.
model PoolDocument {
  id     String         @id @default(cuid())
  poolId String
  pool   InvestmentPool @relation(fields: [poolId], references: [id], onDelete: Cascade)

  memberId String? // documento de um sócio específico (ex.: subscription, extrato)
  docType  String // SUBSCRIPTION | OPERATING_AGREEMENT | NOTE | NOVATION | CAP_TABLE | STATEMENT | DISTRIBUTION_STMT | CLOSING_STMT | OTHER
  fileName String
  pdf      Bytes?
  pdfSize  Int?
  signedAt DateTime? @db.Date
  createdAt DateTime @default(now())

  @@index([poolId])
}
