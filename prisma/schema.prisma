// Prisma schema — Vixus Global Investments
// Fase 0: infraestrutura + modelos de autenticação (Auth.js).
// Os modelos de domínio (Company, Party, Ownership, Ledger, Loans...) entram na Fase 1.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Conexão direta (sem pooler) para migrations. Local = DATABASE_URL; em produção
  // (Supabase) o DATABASE_URL passa pelo transaction pooler e o DIRECT_URL é a sessão.
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// Autenticação (Auth.js / @auth/prisma-adapter)
// ─────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  BOOKKEEPER
  VIEWER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(VIEWER)
  passwordHash  String? // login por credenciais (equipe interna)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────
// Domínio — empresas, donos e ownership (recursivo / UBO)
// ─────────────────────────────────────────────────────────────

enum PartyKind {
  PERSON
  ENTITY
}

enum Jurisdiction {
  PT
  BR
  US
  OTHER
}

// Tipologias (flat — a combinação válida com a jurisdição é checada na app/Zod).
enum EntityType {
  LLC
  C_CORP
  S_CORP
  PA
  LP
  LLP
  SOLE_PROP
  LTDA
  SLU
  SA
  MEI
  EI
  LDA
  UNIPESSOAL_LDA
  ENI
  OTHER
}

enum CompanyRelationship {
  GROUP_MEMBER
  MANAGED_ONLY
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
}

model Party {
  id              String       @id @default(cuid())
  kind            PartyKind
  name            String
  aliases         String[]     @default([]) // nomes alternativos/divergentes (matching de import + merge)
  taxJurisdiction Jurisdiction @default(OTHER)
  taxId           String?
  controlsTax     Boolean      @default(true) // tomamos conta do 1040 desta pessoa? false = externo (ex-sócio, K-1 de fora) — fica fora da sequência de fechamento
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  ownerStakes Ownership[] @relation("OwnerParty")
  ownedStakes Ownership[] @relation("OwnedParty")
  personalReturns PersonalReturn[]
}

model Company {
  id            String              @id @default(cuid())
  legalName     String
  tradeName     String?
  aliases       String[]            @default([]) // nomes alternativos/antigos vistos no QBO (matching de import)
  jurisdiction  Jurisdiction
  state         String? // ex.: "FL"
  entityType    EntityType
  taxId         String? // EIN / NIF / CNPJ
  formationDate String? // data de abertura/constituição (do IR ou doc societário) — p/ anos faltantes
  fiscalYearEnd String              @default("12-31")
  baseCurrency  String              @default("USD")
  relationship  CompanyRelationship
  status        CompanyStatus       @default(ACTIVE)
  collectsSalesTax Boolean          @default(false) // revende produtos → FL Sales & Use Tax
  hasEmployees     Boolean          @default(false) // folha → payroll (941/940/RT-6)
  monitored        Boolean          @default(true) // controlar no fechamento/overview? (false = ex-sócio etc.)
  controlsTax      Boolean          @default(false) // tomamos conta do IR? (gerida fora do grupo entra no closing)
  // Entidade DESCONSIDERADA (disregarded): LLC de sócio único que não declara IR próprio — o resultado é
  // consolidado no IR da dona (esta FK). Ex.: BuildPro (100% da Vixus) entra no 1065 da Vixus. É uma
  // eleição fiscal, NÃO se infere de "100% dono" (um sub 100% pode ser C-corp e declarar sozinho).
  disregardedIntoId String?
  disregardedInto   Company?  @relation("Disregarded", fields: [disregardedIntoId], references: [id], onDelete: SetNull)
  closedDate    String? // data/ano de encerramento — anos depois = N/A; ano do fecho = só IR final
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  disregardedChildren Company[]      @relation("Disregarded") // entidades desconsideradas declaradas DENTRO desta
  ownerStakes     Ownership[]        @relation("OwnerCompany")
  ownedStakes     Ownership[]        @relation("OwnedCompany")
  loansAsLender   IntercompanyLoan[] @relation("Lender")
  loansAsBorrower IntercompanyLoan[] @relation("Borrower")
  qboImports      QboImport[]
  ledgerTxns      LedgerTxn[]
  bankStatements  BankStatement[]
  taxStatuses     CompanyTaxStatus[]
  taxReturns      TaxReturn[]
  yearCloses      YearClose[]
  corporateDocs   CorporateDoc[]
  yearNotes       CompanyYearNote[]
  obligationStatuses ObligationStatus[]
  fixedAssets     FixedAsset[]
  reserveDeposits ReserveDeposit[]
  stateTaxFilings StateTaxFiling[]
}

// Aporte real na conta de reserva de imposto (caixa que foi movido) — para comparar com o
// necessário (funded vs needed) por trimestre.
model ReserveDeposit {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  year        Int
  quarter     Int // 1-4
  amount      Decimal   @db.Decimal(20, 4)
  purpose     String    @default("RESERVE") // RESERVE | LOAN_REPAYMENT | INTEREST | OTHER
  qboRef      String? // onde aparece no QBO da empresa (rastreabilidade)
  depositedAt DateTime? @db.Date
  note        String?
  createdAt   DateTime  @default(now())

  @@index([companyId, year])
}

// Imposto estadual de renda apurado/pago (ex.: Florida F-1120), por empresa e ano de competência.
// Separa principal (dedutível no ano de competência), multa (não dedutível §162(f)) e juros
// (dedutíveis p/ C-corp §163). A data de pagamento define em que ano o principal+multa entram como
// add-back no Schedule M-1 (foram deduzidos/lançados em anos diferentes). É a fonte que explica o
// add-back de "State income tax" sem precisar perguntar ao contador.
model StateTaxFiling {
  id           String    @id @default(cuid())
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jurisdiction String    @default("FL") // estado (FL, etc.)
  taxYear      Int // ano de competência (ex.: 2024 = F-1120 de 2024)
  principal    Decimal   @db.Decimal(20, 2) // imposto (dedutível no federal no ano de competência)
  penalty      Decimal   @default(0) @db.Decimal(20, 2) // multa — não dedutível
  interest     Decimal   @default(0) @db.Decimal(20, 2) // juros — dedutíveis p/ C-corp
  paidDate     DateTime? @db.Date // quando foi pago (define o ano do add-back no M-1)
  source       String? // origem do registro (ex.: "F-1120 notice", recibo)
  note         String?
  createdAt    DateTime  @default(now())

  @@unique([companyId, jurisdiction, taxYear])
  @@index([companyId])
}

// Ativo fixo depreciável (US/MACRS). Guarda tipo, data em serviço, custo e as opções de
// aceleração (§179 / bonus). A depreciação é CALCULADA pelo motor (macrs.ts), não armazenada.
model FixedAsset {
  id              String    @id @default(cuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name            String
  regime          String    @default("US") // US (MACRS) | PT (quotas constantes, DR 25/2009)
  category        String // US: AUTO|COMPUTER|EQUIPMENT|… ; PT: BUILDING_COMM|VEHICLE_LIGHT|…
  acquisitionDate DateTime  @db.Date // colocado em serviço / entrada em uso
  cost            Decimal   @db.Decimal(20, 4)
  recoveryYears   Decimal   @db.Decimal(4, 1) // US: 5, 7, 15, 27.5, 39… ; PT: derivado da taxa
  method          String // MACRS | SL_MM (real property) | SL_PT (quotas constantes)
  ratePct         Decimal   @default(0) @db.Decimal(6, 3) // PT: taxa anual de depreciação (%)
  landValue       Decimal   @default(0) @db.Decimal(20, 4) // PT: parcela de terreno (não deprecia)
  section179      Decimal   @default(0) @db.Decimal(20, 4) // US: deduzido no 1º ano
  bonusPct        Decimal   @default(0) @db.Decimal(5, 2) // US: % de bonus depreciation (após §179)
  // Contador depreciou o ativo TOTALMENTE no livro até este ano (ex.: tudo no ano de aquisição, ou
  // catch-up acelerado em ano posterior). Quando setado, o motor trunca: acumulada = custo até este
  // ano, e $0 depois (sem projeção futura). Confirmado pelo usuário — nunca aplicado sozinho.
  fullyDepreciatedYear Int?
  disposalDate    DateTime? @db.Date
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  yearDepreciations AssetYearDepreciation[]

  @@index([companyId])
}

// Depreciação REAL lançada nos livros, por ativo e ano (o que de fato foi depreciado). Entrada
// manual (confirmada pelo usuário) — usada para comparar com a MACRS "deveria", ativo a ativo.
model AssetYearDepreciation {
  id        String     @id @default(cuid())
  assetId   String
  asset     FixedAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  year      Int
  amount    Decimal    @db.Decimal(20, 2)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([assetId, year])
  @@index([assetId])
}

// Status de uma instância de obrigação (empresa + obrigação + período). Ausência da linha
// = pendente. Permite marcar "feito" (FILED) ou "não se aplica" (NA) no calendário.
model ObligationStatus {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  key       String // chave da obrigação (ex.: "fl-sales-tax")
  periodKey String // ex.: "2026-03", "2026-Q1", "2026"
  status    String    @default("FILED") // FILED | NA
  filedDate DateTime? @db.Date
  note      String?
  updatedAt DateTime  @updatedAt

  @@unique([companyId, key, periodKey])
  @@index([companyId])
}

// Nota livre por empresa/ano — para justificar divergências que não fecham automaticamente
// (ex.: distribuição lançada com estrutura diferente no QBO, ou no topo da cadeia sem
// contraparte) e lembrar a razão no futuro.
model CompanyYearNote {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  year      Int
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, year])
}

// Documentos societários/constitutivos (Articles of Organization, Operating Agreement,
// Sunbiz Annual Report, etc.). A Claude lê o PDF e extrai os dados oficiais (agente
// registrado, administradores/membros, endereços, nº de registro) — p/ conferir, ano a
// ano, se o que está registrado no estado bate com o IR declarado.
model CorporateDoc {
  id          String   @id @default(cuid())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  matchedName String? // nome lido no documento
  label       String? // nome dado pelo usuário (usado quando docType = OTHER, sem referência)
  docType     String // ARTICLES | OPERATING_AGREEMENT | ANNUAL_REPORT | CERTIFICATE | EIN_LETTER | OTHER
  year        Int? // ano do annual report / período
  jurisdiction String?
  state       String?
  docNumber   String? // nº de registro estadual (ex.: Sunbiz)
  taxId       String? // FEI/EIN
  formationDate String?
  filingDate    String?
  status        String?
  registeredAgent  Json? // { name, address }
  principalAddress String?
  mailingAddress   String?
  people      Json? // administradores/membros/diretores: [{ name, title, address }]
  fileName    String
  pdf         Bytes?
  pdfSize     Int?
  confidence  String?
  summary     String?
  createdAt   DateTime @default(now())
}

// Declaração de imposto da PESSOA FÍSICA (ex.: Form 1040 / IRS Tax Return Transcript).
// Fecha o ciclo entidade→sócio: confere se o K-1 que cada LLC alocou ao sócio realmente
// chegou no Schedule E do 1040 dele. SSN guardado só nos últimos 4 dígitos.
model PersonalReturn {
  id             String  @id @default(cuid())
  partyId        String?
  party          Party?  @relation(fields: [partyId], references: [id], onDelete: SetNull)
  matchedName    String? // nome do contribuinte lido no transcript
  spouseName     String?
  ssnLast4       String?
  spouseSsnLast4 String?
  year           Int?
  filingStatus   String? // ex.: "Married Filing Joint"
  form           String? // ex.: "1040"
  preparer       String?
  wages             Decimal? @db.Decimal(20, 2)
  ordinaryDividends Decimal? @db.Decimal(20, 2) // 1040 linha 3b (inclui dividendos de C-Corp)
  qualifiedDividends Decimal? @db.Decimal(20, 2) // 1040 linha 3a
  businessIncomeC   Decimal? @db.Decimal(20, 2) // Schedule C
  capitalGain       Decimal? @db.Decimal(20, 2) // Schedule D
  rentalIncome      Decimal? @db.Decimal(20, 2) // Schedule E aluguel/royalties
  partnershipIncome Decimal? @db.Decimal(20, 2) // Schedule E partnership/S-corp (renda)
  partnershipLoss   Decimal? @db.Decimal(20, 2) // Schedule E partnership/S-corp (perda)
  totalIncome       Decimal? @db.Decimal(20, 2)
  agi               Decimal? @db.Decimal(20, 2)
  taxableIncome     Decimal? @db.Decimal(20, 2)
  totalTax          Decimal? @db.Decimal(20, 2)
  seTax             Decimal? @db.Decimal(20, 2)
  qbiDeduction      Decimal? @db.Decimal(20, 2)
  confidence     String?
  summary        String?
  fileName       String
  pdf            Bytes?
  pdfSize        Int?
  createdAt      DateTime @default(now())
}

// "Fechamento" de um ano conferido: congela a verdade de referência (sócios,
// tributação e os números-chave do IR). Depois disso, um IR reenviado que
// divergir do snapshot vira alerta ("possível erro do contador"). A presença
// da linha = ano travado; reabrir = apagar a linha.
model YearClose {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  year      Int
  lockedAt  DateTime @default(now())
  lockedBy  String // e-mail do usuário que fechou
  snapshot  Json // { owners:[{name,pct,role}], taxTreatment, entityType, taxForm, figures:[{key,label,value}] }
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, year])
}

enum TaxReturnStatus {
  ANALYZED
  APPLIED
}

// IR (declaração) enviado pelo operador; a Claude extrai sócios + forma de tributação.
model TaxReturn {
  id           String          @id @default(cuid())
  fileName     String
  companyId    String?
  company      Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  matchedName  String? // nome da empresa lido no IR
  taxId        String? // EIN/CNPJ/NIF da entidade
  year         Int?
  jurisdiction String?
  entityType   String?
  taxTreatment String?
  taxForm      String? // ex.: "Form 1120-S", "1065", "ECF"
  city         String?
  state        String?
  preparer     String? // contador/escritório que preparou
  responsible  String? // ex.: Partnership Representative / responsável
  ordinaryIncome Decimal? @db.Decimal(20, 2)
  totalIncome    Decimal? @db.Decimal(20, 2)
  netIncome      Decimal? @db.Decimal(20, 2)
  businessActivity  String?
  incorporationDate String?
  address           String?
  // ⚠️ NÃO ler `figures` direto em telas/cálculos — use effectiveFiguresOf(ret) de @/lib/ir/figures
  // (mescla `figures` + `manualFigures`). Ler só `figures` ignora os ajustes manuais = fonte de verdade
  // divergente. Ver o helper para a lista de consumidores.
  figures      Json? // linhas LIDAS do IR (IA): [{ key, label, value, line }]
  manualFigures Json? // ajustes MANUAIS auditáveis: [{ key, label, value, line, note, addedAt }] —
  // ex.: depreciação que estava no IR mas não destacada/extraída. Sobrepõe `figures` por key.
  confidence   String?
  summary      String?
  owners       Json? // [{ name, taxIdLast4, ownershipPct, allocatedIncome, role }]
  k1sReceived  Json? // K-1 RECEBIDOS de investidas: [{ issuerName, issuerEin, amount }]
  isFinalReturn Boolean @default(false) // "Final return" marcado (entidade encerrada no ano)
  pdf          Bytes? // arquivo original, para consulta/registro
  pdfSize      Int?
  status       TaxReturnStatus @default(ANALYZED)
  createdAt    DateTime        @default(now())
}

// Forma de tributação (independe do tipo legal — ex.: LLC tributada como S-corp).
enum TaxTreatment {
  // EUA
  DISREGARDED // LLC single-member (Schedule C/E)
  PARTNERSHIP // 1065
  S_CORP // 1120-S
  C_CORP // 1120
  SOLE_PROP // Schedule C
  // Brasil
  LUCRO_REAL
  LUCRO_PRESUMIDO
  SIMPLES_NACIONAL
  MEI
  // Portugal
  REGIME_GERAL
  REGIME_SIMPLIFICADO
  OTHER
}

// Classificação tributária por ANO (muda ao longo do tempo).
model CompanyTaxStatus {
  id           String       @id @default(cuid())
  companyId    String
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  year         Int
  entityType   EntityType // tipo legal naquele ano
  taxTreatment TaxTreatment // como foi tributada naquele ano
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([companyId, year])
}

// Alíquota de reserva de IR (provisão mensal). `companyId` = id da empresa, ou o
// sentinela "GLOBAL" para o default do grupo. Sem FK (por causa do sentinela).
model TaxReserveRate {
  companyId String   @id // id da empresa ou "GLOBAL"
  ratePct   Decimal  @db.Decimal(5, 2)
  updatedAt DateTime @updatedAt
}

// Alíquotas de provisão por ANO (mudam no tempo). C-corp = federal 21%; pass-through/PF = 30%;
// Florida corporate 5,5% + isenção $50k. Override por empresa continua em TaxReserveRate.
model TaxRateYear {
  year        Int      @id
  corpPct     Decimal  @default(21) @db.Decimal(5, 2)
  passPct     Decimal  @default(30) @db.Decimal(5, 2)
  flPct       Decimal  @default(5.5) @db.Decimal(5, 2)
  flExemption Decimal  @default(50000) @db.Decimal(20, 2)
  updatedAt   DateTime @updatedAt
}

// Fechamento da provisão de um ANO: snapshot dos números no momento do fecho. Trava a tela
// (somente leitura) — é provisão, pode reabrir, mas o snapshot fica como registro.
model ReserveLock {
  year     Int      @id
  lockedAt DateTime @default(now())
  snapshot Json
}

// ─────────────────────────────────────────────────────────────
// Importações do QuickBooks (QBO) — relatórios em CSV
// ─────────────────────────────────────────────────────────────

enum QboReportKind {
  BALANCE_SHEET
  PROFIT_AND_LOSS
  GENERAL_LEDGER
  UNKNOWN
}

model QboImport {
  id                String        @id @default(cuid())
  companyId         String?
  company           Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  sourceCompanyName String // nome exatamente como veio no CSV
  reportKind        QboReportKind
  reportTypeLabel   String
  periodLabel       String
  basis             String?
  fileName          String?
  columns           String[]
  createdAt         DateTime      @default(now())

  lines            QboImportLine[]
  ledgerTxns       LedgerTxn[]
  accountSummaries GlAccountSummary[]
}

// Saldo por conta extraído de um General Ledger (saldo inicial/final da seção).
// Permite cruzar o razão com o Balance Sheet (saldo final) e o P&L (movimento).
model GlAccountSummary {
  id        String    @id @default(cuid())
  importId  String
  import    QboImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  companyId String
  account   String
  beginning Decimal?  @db.Decimal(20, 4)
  ending    Decimal?  @db.Decimal(20, 4)

  @@index([companyId])
  @@index([importId])
}

// Contato (fornecedor/cliente/contraparte) — populado da coluna "Name" do GL.
model Vendor {
  id               String      @id @default(cuid())
  name             String
  normalizedKey    String      @unique
  matchedCompanyId String?
  matchedPartyId   String?
  createdAt        DateTime    @default(now())
  txns             LedgerTxn[]
}

// Extrato bancário importado (por banco/adaptador) — para reconciliação.
model BankStatement {
  id               String    @id @default(cuid())
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bankId           String // "boa", etc.
  bankLabel        String
  glAccount        String? // conta-caixa correspondente no GL (escopa a conciliação)
  fileName         String?
  periodStart      DateTime? @db.Date
  periodEnd        DateTime? @db.Date
  beginningBalance Decimal?  @db.Decimal(20, 4)
  endingBalance    Decimal?  @db.Decimal(20, 4)
  createdAt        DateTime  @default(now())

  lines BankStatementLine[]
}

enum BankLineStatus {
  UNREVIEWED
  MATCHED
  FLAGGED // no razão falta o lançamento (booking faltante)
  IGNORED
}

model BankStatementLine {
  id           String         @id @default(cuid())
  statementId  String
  statement    BankStatement  @relation(fields: [statementId], references: [id], onDelete: Cascade)
  date         DateTime       @db.Date
  description  String
  amount       Decimal        @db.Decimal(20, 4)
  balance      Decimal?       @db.Decimal(20, 4)
  matchedTxnId String? // LedgerTxn reconciliada (no split, o 1º dos lançamentos)
  matchedTxnIds String[] @default([]) // todos os lançamentos casados (split = N)
  matchNote    String? // ex.: "split — 3 entries" (1 linha do banco = N lançamentos no GL)
  status       BankLineStatus @default(UNREVIEWED)
  note         String?
  reviewedAt   DateTime?
  createdAt    DateTime       @default(now())
}

// Linha do razão (General Ledger) — uma transação por conta.
model LedgerTxn {
  id          String     @id @default(cuid())
  companyId   String
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  importId    String?
  import      QboImport? @relation(fields: [importId], references: [id], onDelete: SetNull)
  account     String
  date        DateTime   @db.Date
  type        String
  num         String?
  vendorId    String?
  vendor      Vendor?    @relation(fields: [vendorId], references: [id])
  rawName     String?
  description String?
  split       String?
  amount      Decimal    @db.Decimal(20, 4)
  currency    String     @default("USD")
  createdAt   DateTime   @default(now())

  @@index([companyId, account])
  @@index([companyId, date])
}

// Taxas de câmbio travadas por data (buscadas online, ex.: fim de mês).
model FxRate {
  id        String   @id @default(cuid())
  base      String // moeda base, ex.: "USD"
  quote     String // moeda cotada, ex.: "BRL", "EUR" (1 base = rate quote)
  date      DateTime @db.Date
  rate      Decimal  @db.Decimal(18, 8)
  source    String   @default("frankfurter")
  fetchedAt DateTime @default(now())

  @@unique([base, quote, date])
}

model QboImportLine {
  id          String    @id @default(cuid())
  importId    String
  import      QboImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  rowIndex    Int
  label       String
  accountCode String?
  sectionPath String[]
  depth       Int
  lineType    String // SECTION | ACCOUNT | TOTAL
  value       Decimal?  @db.Decimal(20, 4) // valor da 1ª coluna de período
  currency    String    @default("USD")
}

/// Aresta de participação genérica. Dono e possuído podem ser Party OU Company,
/// permitindo a árvore recursiva até o beneficiário final (UBO).
/// Regra (validada na app): exatamente UM owner* e UM owned* preenchidos.
model Ownership {
  id String @id @default(cuid())

  ownerPartyId   String?
  ownerParty     Party?   @relation("OwnerParty", fields: [ownerPartyId], references: [id])
  ownerCompanyId String?
  ownerCompany   Company? @relation("OwnerCompany", fields: [ownerCompanyId], references: [id])

  ownedCompanyId String?
  ownedCompany   Company? @relation("OwnedCompany", fields: [ownedCompanyId], references: [id])
  ownedPartyId   String?
  ownedParty     Party?   @relation("OwnedParty", fields: [ownedPartyId], references: [id])

  percentage    Decimal   @db.Decimal(9, 6) // 0–100
  shareClass    String?
  effectiveDate DateTime  @default(now())
  endDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ─────────────────────────────────────────────────────────────
// Empréstimos intercompany (juros simples + origination fee)
// ─────────────────────────────────────────────────────────────

enum LoanStatus {
  ACTIVE
  PAID
  DEFAULTED
  CANCELLED
}

enum LoanInterestMethod {
  SIMPLE
  COMPOUND
}

enum DayCountBasis {
  ACT_365
  ACT_360
  D30_360
}

enum LoanTxnType {
  DISBURSEMENT
  ORIGINATION_FEE
  INTEREST_ACCRUAL
  REPAYMENT_PRINCIPAL
  REPAYMENT_INTEREST
  ADJUSTMENT
}

model IntercompanyLoan {
  id                String   @id @default(cuid())
  lenderCompanyId   String
  lender            Company  @relation("Lender", fields: [lenderCompanyId], references: [id])
  borrowerCompanyId String
  borrower          Company  @relation("Borrower", fields: [borrowerCompanyId], references: [id])

  principal          Decimal            @db.Decimal(20, 4)
  currency           String             @default("USD")
  annualInterestRate Decimal            @db.Decimal(9, 6) // fração anual: 0.085 = 8,5%
  interestMethod     LoanInterestMethod @default(SIMPLE)
  dayCountBasis      DayCountBasis      @default(ACT_365)
  originationFeeRate Decimal            @default(0.01) @db.Decimal(9, 6) // configurável; padrão 1%

  startDate    DateTime
  maturityDate DateTime?
  status       LoanStatus @default(ACTIVE)
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  transactions LoanTransaction[]
  years        LoanYear[]
}

// Valores FORNECIDOS por ano de um empréstimo intercompany (do contador/QBO). O app não
// recalcula o juro — guarda o que é informado e faz o roll-forward do juro não pago para uma
// conta SEPARADA (juro capitalizado), que fica apartada do principal para bater com o QBO.
// AGENDA por ano de um empréstimo: taxa vigente + juro pago no ano. O PRINCIPAL é fonte única em
// LoanTransaction (buildAnnualClosings/computeLoanBalance); o juro accrued é CALCULADO. As colunas de
// principal/accrued vestigiais foram removidas (migração drop_loanyear_vestigial, com guarda anti-perda).
model LoanYear {
  id            String           @id @default(cuid())
  loanId        String
  loan          IntercompanyLoan @relation(fields: [loanId], references: [id], onDelete: Cascade)
  year          Int
  annualRatePct Decimal?         @db.Decimal(9, 4) // taxa do ano (%, reajustável) — USADO
  interestPaid  Decimal          @default(0) @db.Decimal(20, 2) // juro pago no ano (fornecido) — USADO
  note          String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([loanId, year])
}

model LoanTransaction {
  id     String           @id @default(cuid())
  loanId String
  loan   IntercompanyLoan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  type      LoanTxnType
  amount    Decimal     @db.Decimal(20, 4)
  date      DateTime
  memo      String?
  createdAt DateTime    @default(now())
}
