# ── Banco ────────────────────────────────────────────────
DATABASE_URL="postgresql://user:pass@host:5432/vixus?schema=public"
DIRECT_URL="postgresql://user:pass@host:5432/vixus"

# ── Auth ─────────────────────────────────────────────────
AUTH_SECRET="<openssl rand -base64 32>"
AUTH_TRUST_HOST="true"

# ── IA (leitura de documentos: LOI, contratos, budget) ───
ANTHROPIC_API_KEY="sk-ant-..."

# ── E-mail transacional (#69: convite do portal, avisos) ─
# Sem estas variáveis o app NÃO quebra: o convite continua gerando o link
# para o operador enviar manualmente. Com elas, o envio é automático.
RESEND_API_KEY="re_..."                                   # console.resend.com → API Keys
MAIL_FROM="Vixus <no-reply@vixusglobal.com>"              # domínio VERIFICADO no Resend
MAIL_REPLY_TO="stefan@4youhomes.com"                      # opcional: respostas vão p/ cá
