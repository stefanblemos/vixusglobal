# Banco de dados (PostgreSQL)
# Local: o Postgres da máquina. Produção (Vercel): a connection string do Neon
# (use a URL "pooled" do Neon, com ?sslmode=require, para serverless).
DATABASE_URL="postgresql://vixus_app:vixus_dev_local@localhost:5432/vixus_dev?schema=public"

# Auth.js — gere um segredo com: npx auth secret  (ou openssl rand -base64 32)
AUTH_SECRET="troque-por-um-segredo-forte"

# Em produção atrás de proxy (Vercel), o Auth.js precisa confiar no host:
# AUTH_TRUST_HOST="true"

# Análise de IR via Claude (necessária p/ a tela /tax). Obtenha em console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# Storage de arquivos: "local" agora; "spaces" (Digital Ocean) depois
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="./.storage"
